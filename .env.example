# Renatus environment — copy to .env.local, never commit secrets.
#
# v3 architecture: Postgres (audit + graph via recursive CTEs), Inngest (workflow),
# multi-provider LLM routing. Neo4j and Redis were dropped in v3.

# ─── Postgres (audit chain + codebase graph) ─────────────────────────────────
# Neon serverless Postgres. The mcp_sessions / tool_invocations / jobs tables live here.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ─── LLM providers (router picks per call — see SYSTEM-DESIGN.md §7) ─────────
# Default low-latency provider.
GROQ_API_KEY=""

# Large-context fallback (>100k token jobs).
GEMINI_API_KEY=""

# IBM Granite via watsonx.ai. Sponsor signal — also unlocks $80 IBM credits.
WATSONX_API_KEY=""
WATSONX_PROJECT_ID=""

# Optional: Vercel AI Gateway for multi-provider routing with one key.
VERCEL_AI_GATEWAY_URL=""
VERCEL_AI_GATEWAY_API_KEY=""

# Set to "true" to let the MCP elicitation adapter participate in router selection.
# Default off so standalone smoke tests hit real providers (Groq/Gemini), not the stub.
MCP_ENABLE_ELICITATION=""

# ─── MCP audit ───────────────────────────────────────────────────────────────
# Optional: stable session id across process restarts. If unset, a random UUID is generated.
BOB_TASK_ID=""

# ─── Inngest (durable orchestrator) ──────────────────────────────────────────
# Local dev server runs at http://localhost:8288. Production: cloud.inngest.com.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── Deployment (Vercel) ─────────────────────────────────────────────────────
VERCEL_TOKEN=""
